VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Local Supabase CLI/self-hosted fallback:
# VITE_SUPABASE_ANON_KEY=your-local-anon-key
# Local Supabase Google OAuth secret goes in .env before enabling the provider template in supabase/config.toml:
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=your-google-client-secret
