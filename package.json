{
  "name": "myapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "supabase:init": "npx supabase init --yes",
    "supabase:start": "npx supabase start",
    "supabase:status": "npx supabase status",
    "supabase:stop": "npx supabase stop",
    "cf:build": "npm run build",
    "cf:functions:build": "mkdir -p .wrangler/pages-bundle && wrangler pages functions build functions --outdir .wrangler/pages-bundle",
    "cf:dev": "npm run build && npm run cf:functions:build && wrangler dev .wrangler/pages-bundle/index.js --assets dist --local --env-file .dev.vars",
    "cf:deploy": "npm run build && wrangler pages deploy"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "html-to-image": "^1.11.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "standardwebhooks": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0"
  }
}
